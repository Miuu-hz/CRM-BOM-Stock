// Prisma Schema for CRM-BOM-Stock Management System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User Management
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// CRM - Customer Management
model Customer {
  id           String         @id @default(cuid())
  code         String         @unique
  name         String
  type         String
  contactName  String
  email        String
  phone        String
  address      String?
  city         String
  creditLimit  Decimal        @default(0)
  status       String         @default("ACTIVE")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  orders       Order[]

  @@map("customers")
}

// Orders
model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique
  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id])
  orderDate    DateTime    @default(now())
  deliveryDate DateTime?
  totalAmount  Decimal
  status       String      @default("PENDING")
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  items        OrderItem[]

  @@map("orders")
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id])
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Decimal
  totalPrice Decimal

  @@map("order_items")
}

// BOM - Bill of Materials
model Product {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  category    String
  description String?
  status      String        @default("ACTIVE")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  boms        BOM[]
  orderItems  OrderItem[]
  stockItems  StockItem[]

  @@map("products")
}

model BOM {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id])
  version   String
  status    String    @default("DRAFT")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  materials  BOMItem[]
  workOrders WorkOrder[]

  @@unique([productId, version])
  @@map("boms")
}

model Material {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  unit      String
  unitCost  Decimal
  minStock  Int
  maxStock  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bomItems            BOMItem[]
  stockItems          StockItem[]
  purchaseOrderItems  PurchaseOrderItem[]
  workOrderMaterials  WorkOrderMaterial[]

  @@map("materials")
}

model BOMItem {
  id         String   @id @default(cuid())
  bomId      String
  bom        BOM      @relation(fields: [bomId], references: [id])
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  quantity   Decimal
  unit       String

  @@map("bom_items")
}

// Stock/Inventory Management
model StockItem {
  id         String        @id @default(cuid())
  sku        String        @unique
  name       String
  category   String
  productId  String?
  product    Product?      @relation(fields: [productId], references: [id])
  materialId String?
  material   Material?     @relation(fields: [materialId], references: [id])
  quantity   Int
  unit       String
  minStock   Int
  maxStock   Int
  location   String
  status     String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  movements  StockMovement[]

  @@map("stock_items")
}

model StockMovement {
  id          String             @id @default(cuid())
  stockItemId String
  stockItem   StockItem          @relation(fields: [stockItemId], references: [id])
  type        String
  quantity    Int
  reference   String?
  notes       String?
  createdAt   DateTime           @default(now())
  createdBy   String

  @@map("stock_movements")
}

// Supplier Management (อ้างอิง Carbon ERP pattern)
model Supplier {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  type         String   // RAW_MATERIAL, PACKAGING, SERVICE, OTHER
  contactName  String
  email        String
  phone        String
  address      String?
  city         String?
  taxId        String?
  paymentTerms String   @default("NET30") // NET15, NET30, NET60, COD
  rating       Int      @default(0) // 0-5 stars
  status       String   @default("ACTIVE") // ACTIVE, INACTIVE, BLOCKED
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

// Purchase Orders (ใบสั่งซื้อ - อ้างอิง Carbon ERP)
model PurchaseOrder {
  id             String   @id @default(cuid())
  poNumber       String   @unique
  supplierId     String
  supplier       Supplier @relation(fields: [supplierId], references: [id])
  status         String   @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, RECEIVED, PARTIAL, CANCELLED
  orderDate      DateTime @default(now())
  expectedDate   DateTime?
  receivedDate   DateTime?
  subtotal       Decimal  @default(0)
  taxRate        Decimal  @default(0)
  taxAmount      Decimal  @default(0)
  totalAmount    Decimal  @default(0)
  notes          String?
  createdBy      String?
  approvedBy     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  materialId      String
  material        Material      @relation(fields: [materialId], references: [id])
  quantity        Decimal
  unitPrice       Decimal
  totalPrice      Decimal
  receivedQty     Decimal       @default(0)
  unit            String
  notes           String?

  @@map("purchase_order_items")
}

// Work Orders (ใบสั่งผลิต - อ้างอิง Carbon ERP MES)
model WorkOrder {
  id              String   @id @default(cuid())
  woNumber        String   @unique
  bomId           String
  bom             BOM      @relation(fields: [bomId], references: [id])
  quantity        Int      // จำนวนที่ต้องผลิต
  completedQty    Int      @default(0) // จำนวนที่ผลิตเสร็จ
  scrapQty        Int      @default(0) // จำนวนของเสีย
  status          String   @default("DRAFT") // DRAFT, PLANNED, IN_PROGRESS, COMPLETED, CANCELLED, ON_HOLD
  priority        String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  startDate       DateTime?
  dueDate         DateTime?
  completedDate   DateTime?
  assignedTo      String?
  notes           String?
  estimatedCost   Decimal  @default(0)
  actualCost      Decimal  @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  materialUsages WorkOrderMaterial[]

  @@map("work_orders")
}

model WorkOrderMaterial {
  id          String    @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  materialId  String
  material    Material  @relation(fields: [materialId], references: [id])
  requiredQty Decimal
  issuedQty   Decimal   @default(0) // จำนวนที่เบิกจริง
  unit        String
  status      String    @default("PENDING") // PENDING, ISSUED, RETURNED

  @@map("work_order_materials")
}

// Marketing Module
model Shop {
  id        String   @id @default(cuid())
  name      String
  platform  String
  shopId    String   // Platform-specific shop ID
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  marketingFiles   MarketingFile[]
  marketingMetrics MarketingMetric[]

  @@unique([platform, shopId])
  @@map("shops")
}

model MarketingFile {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  fileName    String
  filePath    String
  platform    String
  userName    String?
  reportStart DateTime?
  reportEnd   DateTime?
  rowCount    Int      @default(0)
  uploadedAt  DateTime @default(now())

  metrics MarketingMetric[]

  @@map("marketing_files")
}

model MarketingMetric {
  id             String        @id @default(cuid())
  fileId         String
  file           MarketingFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  shopId         String
  shop           Shop          @relation(fields: [shopId], references: [id])

  // Date
  date           DateTime

  // Campaign/Product Info
  campaignName   String?
  productName    String?
  sku            String?
  adStatus       String?       // สถานะโฆษณา

  // Performance Metrics
  impressions    Int           @default(0)        // การมองเห็น
  clicks         Int           @default(0)        // จำนวนคลิก
  ctr            Decimal       @default(0)        // อัตราการคลิก (CTR)

  // Orders
  orders         Int           @default(0)        // การสั่งซื้อ
  directOrders   Int           @default(0)        // การสั่งซื้อโดยตรง
  orderRate      Decimal       @default(0)        // อัตราการสั่งซื้อ
  directOrderRate Decimal      @default(0)        // อัตราการสั่งซื้อโดยตรง

  // Cost
  costPerOrder   Decimal       @default(0)        // ราคาต่อการสั่งซื้อ
  directCostPerOrder Decimal   @default(0)        // ราคาต่อการสั่งซื้อโดยตรง

  // Items Sold
  itemsSold      Int           @default(0)        // สินค้าที่ขายแล้ว
  directItemsSold Int          @default(0)        // สินค้าที่ขายแล้วโดยตรง

  // Sales
  sales          Decimal       @default(0)        // ยอดขาย
  directSales    Decimal       @default(0)        // ยอดขายโดยตรง

  // Ad Cost
  adCost         Decimal       @default(0)        // ค่าโฆษณา

  // Performance Ratios
  roas           Decimal       @default(0)        // ยอดขาย/รายจ่าย (ROAS)
  directRoas     Decimal       @default(0)        // Direct ROAS
  acos           Decimal       @default(0)        // ACOS
  directAcos     Decimal       @default(0)        // Direct ACOS

  conversionRate Decimal       @default(0)        // อัตราการแปลง

  // Additional metrics (flexible)
  extraData      String?       // JSON string for platform-specific fields

  createdAt      DateTime      @default(now())

  @@index([shopId, date])
  @@map("marketing_metrics")
}
